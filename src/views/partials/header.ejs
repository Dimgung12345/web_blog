<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'eBlog-RPL' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
</head>
<body>
    <header>
        <div class="container header-inner">
            <a href="<%= BASE_PATH %>" class="logo">eBlog-RPL</a>
            <button class="hamburger" id="hamburger" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <nav id="main-nav">
                <ul>
                    <li><a href="<%= BASE_PATH %>">Home</a></li>
                    <li><a href="<%= BASE_PATH %>/posts">All Posts</a></li>
                    <li><a href="<%= BASE_PATH %>/categories">Categories</a></li>
                </ul>
            </nav>
        </div>
    </header>
    <div class="mobile-nav-overlay" id="mobile-nav-overlay"></div>
    <script>
        (function(){
            var h=document.getElementById('hamburger'),n=document.getElementById('main-nav'),o=document.getElementById('mobile-nav-overlay'),b=document.body;
            function toggleNav(){var isOpen=n.classList.toggle('open');h.classList.toggle('active');o.classList.toggle('active');b.classList.toggle('nav-open',isOpen);}
            h.addEventListener('click',toggleNav);
            o.addEventListener('click',toggleNav);
            window.addEventListener('resize',function(){if(window.innerWidth>992){n.classList.remove('open');h.classList.remove('active');o.classList.remove('active');b.classList.remove('nav-open');}});
        })();
    </script>
    <main>
