<aside class="sidebox">
    <div class="sidebox-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 7h18M3 12h18M3 17h18"/></svg>
        Kategori
    </div>
    <div class="sidebox-body">
        <ul class="cat-list">
            <li><a href="<%= BASE_PATH %>/categories">Semua Kategori</a></li>
            <% if (typeof categories !== 'undefined' && categories.length > 0) {
                categories.forEach(function (cat) { %>
                <li>
                    <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"><%= cat.name %></a>
                </li>
            <% }); } else { %>
                <li><span class="text-secondary">Belum ada kategori</span></li>
            <% } %>
        </ul>
    </div>
</aside>
