<%
var _readMin = Math.ceil(((post.content || '').split(/\s+/).length) / 200) || 1;
var _excerpt = (post.content || '').replace(/[#*`]/g, '').substring(0, 140);
%>
<article class="post-card">
    <a href="<%= BASE_PATH %>/posts/<%= post.slug %>" class="post-card-thumb" aria-label="<%= post.title %>">
        <%
            var thumbUrl = post.thumbnail || post.pathID;
            if (thumbUrl) {
                if (!thumbUrl.startsWith('http') && !thumbUrl.startsWith('/')) {
                    thumbUrl = BASE_PATH + '/' + thumbUrl;
                }
        %>
            <img src="<%= thumbUrl %>" alt="<%= post.title %>">
        <% } else { %>
            <div class="post-card-thumb-placeholder"></div>
        <% } %>
    </a>
    <div class="post-card-body">
        <% if (post.Category) { %>
            <a href="<%= BASE_PATH %>/posts/category/<%= post.Category.slug %>"
               class="cat-tag" style="--cat-color: <%= catColor(post.Category.name) %>;">
                <%= post.Category.name %>
            </a>
        <% } %>
        <h3 class="post-card-title">
            <a href="<%= BASE_PATH %>/posts/<%= post.slug %>"><%= post.title %></a>
        </h3>
        <div class="post-card-meta">
            <span><%= post.User ? post.User.username : 'Admin' %></span>
            <span class="post-card-sep">|</span>
            <span><%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('id-ID', { month: 'short', day: 'numeric', year: 'numeric' }) : '-' %></span>
            <span class="post-card-sep">|</span>
            <span><%= _readMin %> mnt baca</span>
        </div>
        <p class="post-card-excerpt"><%= _excerpt %>…</p>
        <a href="<%= BASE_PATH %>/posts/<%= post.slug %>" class="readmore">Baca selengkapnya</a>
    </div>
</article>
