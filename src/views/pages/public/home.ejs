<%- include('../../partials/header', { title: 'Beranda - Blog' }) %>
    <div style="text-align: center; margin-bottom: 40px; background: white; padding: 40px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
        <h1 style="margin-top: 0; color: #2c3e50;">Selamat Datang di Blog</h1>
        <p style="color: #7f8c8d; font-size: 1.1em;">Tempat berbagi wawasan seputar teknologi, sains, dan kehidupan.</p>
        <% if (isLandingPage) { %>
            <div style="margin-top: 20px;">
                <a href="<%= BASE_PATH %>/posts" style="display: inline-block; padding: 10px 20px; background: #3498db; color: white; text-decoration: none; border-radius: 4px; font-weight: bold;">Lihat Semua Postingan &rarr;</a>
            </div>
        <% } %>
    </div>

    <div style="display: flex; gap: 20px;">
        <%- include('../../partials/sidebar') %>

        <section style="flex: 1;">
            <% if (posts.length===0) { %>
                <p>Belum ada postingan.</p>
                <% } else { %>
                    <% posts.forEach(post=> { %>
                        <article
                            style="background: white; padding: 20px; border-radius: 8px; margin-bottom: 20px; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                            <h2 style="margin-top: 0;"><a href="<%= BASE_PATH %>/posts/<%= post.slug %>"
                                    style="text-decoration: none; color: #2c3e50;">
                                    <%= post.title %>
                                </a></h2>
                            <div style="font-size: 0.9em; color: #7f8c8d; margin-bottom: 15px;">
                                <span style="background: #ecf0f1; padding: 3px 8px; border-radius: 4px;">
                                    <%= post.Category ? post.Category.name : 'Uncategorized' %>
                                </span>
                                &bull; Oleh <%= post.User ? post.User.username : 'Unknown' %>
                                    &bull; <%= new Date(post.createdAt).toLocaleDateString('id-ID') %>
                            </div>
                            <p style="color: #555; line-height: 1.6;">
                                <%= post.content.substring(0, 150) %>...
                            </p>
                            <a href="<%= BASE_PATH %>/posts/<%= post.slug %>"
                                style="color: #3498db; text-decoration: none; font-weight: bold;">Baca selengkapnya
                                &rarr;</a>
                        </article>
                        <% }) %>
                    <% } %>
        </section>
    </div>
    <%- include('../../partials/footer') %>
