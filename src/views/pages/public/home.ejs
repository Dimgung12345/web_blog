<%- include('../../partials/header', { title: 'Blog - Insight Pengembang Perangkat Lunak', activeNav: 'home' }) %>

    <section class="hero">
        <div class="container">
            <h1><%= isLandingPage ? 'Insight & Update Rekayasa Perangkat Lunak' : (typeof title !== 'undefined' && title ? title : 'Semua Artikel') %></h1>
            <p class="hero-sub">
                <% if (isLandingPage) { %>
                    Temukan artikel berkualitas tinggi, tutorial coding, sains, dan perkembangan teknologi terbaru.
                <% } else if (typeof q !== 'undefined' && q) { %>
                    Hasil pencarian untuk kata kunci "<strong><%= q %></strong>"
                <% } else { %>
                    Jelajahi berbagai artikel dan tutorial seputar rekayasa perangkat lunak.
                <% } %>
            </p>
            <form class="search-form" action="<%= BASE_PATH %>/search" method="GET">
                <input type="search" name="query" value="<%= typeof q !== 'undefined' && q ? q : '' %>" placeholder="Cari topik, tutorial, atau bahasa pemrograman..." autocomplete="off">
                <button type="submit" class="btn btn-primary">Cari</button>
            </form>
        </div>
    </section>

    <div class="layout-3col">

        <!-- LEFT SIDEBAR -->
        <div class="sidebar-col sticky-col">
            <%- include('../../partials/sidebar', { categories, BASE_PATH }) %>
        </div>

        <!-- MAIN COLUMN -->
        <div class="main-col">

            <% if (isLandingPage && posts && posts.length > 0) {
                var featuredPost = posts[0];
                var featThumbUrl = featuredPost.thumbnail || featuredPost.pathID;
                if (featThumbUrl && !featThumbUrl.startsWith('http') && !featThumbUrl.startsWith('/')) {
                    featThumbUrl = BASE_PATH + '/' + featThumbUrl;
                }
            %>
            <div class="featured-post">
                <div class="featured-post-thumb">
                    <% if (featThumbUrl) { %>
                        <img src="<%= featThumbUrl %>" alt="<%= featuredPost.title %>">
                    <% } else { %>
                        <div class="post-card-thumb-placeholder" style="height:100%"></div>
                    <% } %>
                    <% if (featuredPost.Category) { %>
                        <span class="featured-post-cat cat-tag" style="--cat-color: <%= catColor(featuredPost.Category.name) %>;">
                            <%= featuredPost.Category.name %>
                        </span>
                    <% } %>
                </div>
                <div class="featured-post-body">
                    <h2 class="featured-post-title">
                        <a href="<%= BASE_PATH %>/posts/<%= featuredPost.slug %>"><%= featuredPost.title %></a>
                    </h2>
                    <div class="featured-post-meta">
                        Oleh <%= featuredPost.User ? featuredPost.User.username : 'Admin' %>
                        | <%= featuredPost.createdAt ? new Date(featuredPost.createdAt).toLocaleDateString('id-ID', { month: 'long', day: 'numeric', year: 'numeric' }) : '-' %>
                    </div>
                    <p class="featured-post-excerpt">
                        <%= (featuredPost.content || '').replace(/[#*`]/g, '').substring(0, 200) %>…
                    </p>
                    <a href="<%= BASE_PATH %>/posts/<%= featuredPost.slug %>" class="readmore">Baca selengkapnya</a>
                </div>
            </div>
            <% } %>

            <div class="section-bar">
                <span><%= isLandingPage ? 'Postingan Terbaru' : 'Daftar Artikel' %></span>
                <a href="<%= BASE_PATH %>/posts">Lihat Semua &raquo;</a>
            </div>

            <div class="posts-list">
                <% var displayPosts = isLandingPage ? (posts || []).slice(1, 7) : posts;
                   if (displayPosts && displayPosts.length > 0) {
                       displayPosts.forEach(function (post) { %>
                    <%- include('../../partials/post-card', { post: post, BASE_PATH: BASE_PATH, catColor: catColor }) %>
                <% }); } else { %>
                    <div class="empty-note">Belum ada artikel.</div>
                <% } %>
            </div>
        </div>

        <!-- UTILITY COLUMN -->
        <div class="utility-col sticky-col">

            <aside class="sidebox">
                <div class="sidebox-title">Topik Kategori</div>
                <div class="sidebox-body">
                    <% if (categories && categories.length > 0) { %>
                        <div class="cat-grid" style="grid-template-columns:1fr 1fr;gap:6px;">
                            <% categories.slice(0, 12).forEach(function (cat) { %>
                                <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"
                                   class="cat-tag" style="--cat-color: <%= catColor(cat.name) %>; display:block; text-align:center; margin-bottom:4px;">
                                    <%= cat.name %>
                                </a>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <span class="text-secondary">Belum ada kategori.</span>
                    <% } %>
                </div>
            </aside>

            <%
                var displayTrending = (typeof trendingPosts !== 'undefined' && trendingPosts.length > 0) ? trendingPosts : (posts || []).slice(1, 6);
                if (displayTrending && displayTrending.length > 0) {
            %>
            <aside class="sidebox">
                <div class="sidebox-title">Postingan Trending</div>
                <div class="sidebox-body" style="padding:4px 0;">
                    <ul class="rank-list">
                        <% displayTrending.forEach(function (post, idx) { %>
                            <li>
                                <a href="<%= BASE_PATH %>/posts/<%= post.slug %>" class="rank-item">
                                    <span class="rank-num"><%= idx + 1 %></span>
                                    <span>
                                        <span class="rank-title"><%= post.title %></span><br>
                                        <span class="rank-meta">
                                            <% if (post.Category) { %><%= post.Category.name %> | <% } %>
                                            <%= post.createdAt ? new Date(post.createdAt).toLocaleDateString('id-ID', { month: 'short', day: 'numeric' }) : '-' %>
                                        </span>
                                    </span>
                                </a>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            </aside>
            <% } %>
        </div>
    </div>

    <%- include('../../partials/footer') %>
