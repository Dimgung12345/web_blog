<%- include('../../partials/header', { title: 'eBlog-RPL - Insight Pengembang Perangkat Lunak' }) %>

<div class="container" style="padding-top: 5rem; padding-bottom: 5rem; max-width: 1400px;">
    <div class="post-layout" style="grid-template-columns: 1fr 300px; gap: 4rem;">
        <section class="posts-content">
            <h2 style="font-family: var(--font-heading); margin-bottom: 2.5rem; font-size: 2rem;">Artikel Terbaru</h2>

            <div class="posts-grid"
                style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem;">
                    <% if (posts && posts.length> 0) { %>
                        <% posts.forEach(post=> { %>
                            <article class="post-card" style="border: none; background: transparent;">
                                <img src="https://placehold.co/600x400" alt="Post thumbnail" class="post-card-image"
                                    style="border-radius: 12px; height: 200px; margin-bottom: 1.5rem; object-fit: cover; width: 100%;">
                                <div class="post-card-content" style="padding: 0;">
                                    <span
                                        style="color: var(--primary-color); font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">
                                        <%= post.Category ? post.Category.name : 'General' %>
                                    </span>
                                    <h3
                                        style="font-family: var(--font-heading); font-size: 1.35rem; margin-bottom: 0.75rem; line-height: 1.3;">
                                        <a href="<%= BASE_PATH %>/posts/<%= post.slug %>"
                                            style="color: var(--text-main);">
                                            <%= post.title %>
                                        </a>
                                    </h3>
                                    <p
                                        style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.25rem; line-height: 1.6;">
                                        <%= post.content.replace(/[#*`]/g, '' ).substring(0, 120) %>...
                                    </p>
                                    <div style="font-size: 0.8rem; font-weight: 600; color: var(--text-muted);">
                                        <%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short' ,
                                            day: 'numeric' , year: 'numeric' }) %>
                                    </div>
                                </div>
                            </article>
                            <% }) %>
                                <% } else { %>
                                    <p style="color: var(--text-muted); grid-column: 1 / -1; padding: 2rem 0;">Belum ada artikel. Cek lagi nanti!</p>
                                    <% } %>
                </div>
            </section>

            <aside class="right-sidebar">
                <div class="sidebar-widget">
                    <h4 style="font-family: var(--font-heading); margin-bottom: 1.5rem;">Jelajahi Kategori</h4>
                    <ul class="related-articles">
                        <% if (categories && categories.length> 0) { %>
                            <% categories.forEach(cat=> { %>
                                <li class="related-item"
                                    style="margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                                    <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"
                                        style="display: flex; justify-content: space-between; align-items: center; font-weight: 600;">
                                        <%= cat.name %>
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M9 18l6-6-6-6"></path>
                                            </svg>
                                    </a>
                                </li>
                                <% }) %>
                                    <% } else { %>
                                        <li style="color: var(--text-muted); font-size: 0.95rem;">Belum ada kategori.</li>
                                        <% } %>
                    </ul>
                </div>
            </aside>
        </div>
    </div>

    <%- include('../../partials/footer') %>