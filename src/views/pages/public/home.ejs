<%- include('../../partials/header', { title: 'eBlog-RPL - Insight Pengembang Perangkat Lunak' }) %>

<%
var catColors = ['#0069ff','#8b5cf6','#10b981','#f59e0b','#ef4444','#ec4899','#06b6d4','#f97316'];
function catColor(name) {
    var h = 0;
    for (var i = 0; i < name.length; i++) { h = ((h << 5) - h) + name.charCodeAt(i); h |= 0; }
    return catColors[Math.abs(h) % catColors.length];
}
%>

<section class="hero-slice">
    <div class="hero-search">
        <div class="container">
            <h1 class="hero-search-title">Ingin mencari topik apa?</h1>
            <p class="hero-search-sub">Temukan insight seputar pengembangan perangkat lunak, teknologi, dan sains.</p>
            <form class="hero-search-form" action="<%= BASE_PATH %>/search" method="GET">
                <svg class="hero-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.35-4.35" />
                </svg>
                <input type="search" name="query" placeholder="Ketik topik atau kata kunci..." autocomplete="off">
                <button type="submit">Cari</button>
            </form>
        </div>
    </div>

    <div class="container" style="padding-top: 3rem; padding-bottom: 5rem; max-width: 1400px;">
        <div class="post-layout" style="grid-template-columns: 1fr 300px; gap: 4rem;">
            <section class="posts-content" style="padding-left: 1.5rem; padding-right: 1rem;">
                <h2 style="font-family: var(--font-heading); margin-bottom: 2.5rem; font-size: 2rem;">Artikel Terbaru</h2>

                <div class="posts-grid"
                    style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem;">
                    <% if (posts && posts.length> 0) { %>
                        <% posts.forEach(post=> { %>
                            <article class="post-card" style="border: none; background: transparent;">
                                <a href="<%= BASE_PATH %>/posts/<%= post.slug %>">
                                    <img src="https://placehold.co/600x400" alt="Post thumbnail" class="post-card-image"
                                        style="border-radius: 12px; height: 200px; margin-bottom: 1.5rem; object-fit: cover; width: 100%;">
                                </a>
                                <div class="post-card-content" style="padding: 0;">
                                    <span
                                        style="color: <%= catColor(post.Category ? post.Category.name : 'General') %>; font-weight: 700; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; display: block; margin-bottom: 0.5rem;">
                                        <%= post.Category ? post.Category.name : 'General' %>
                                    </span>
                                    <h3
                                        style="font-family: var(--font-heading); font-size: 1.35rem; margin-bottom: 0.75rem; line-height: 1.3;">
                                        <a href="<%= BASE_PATH %>/posts/<%= post.slug %>"
                                            style="color: var(--text-main);">
                                            <%= post.title %>
                                        </a>
                                    </h3>
                                    <p
                                        style="color: var(--text-muted); font-size: 0.95rem; margin-bottom: 1.25rem; line-height: 1.6;">
                                        <%= post.content.replace(/[#*`]/g, '' ).substring(0, 120) %>...
                                    </p>
                                    <div class="post-date">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                            stroke-linejoin="round">
                                            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                                            <line x1="16" y1="2" x2="16" y2="6" />
                                            <line x1="8" y1="2" x2="8" y2="6" />
                                            <line x1="3" y1="10" x2="21" y2="10" />
                                        </svg>
                                        <%= new Date(post.createdAt).toLocaleDateString('en-US', { month: 'short' ,
                                            day: 'numeric' , year: 'numeric' }) %>
                                    </div>
                                </div>
                            </article>
                            <% }) %>
                                <% } else { %>
                                    <p style="color: var(--text-muted); grid-column: 1 / -1; padding: 2rem 0;">Belum ada
                                        artikel. Cek lagi nanti!</p>
                                    <% } %>
                </div>
            </section>

            <aside class="right-sidebar">
                <div class="sidebar-widget">
                    <h4 style="font-family: var(--font-heading); margin-bottom: 1.5rem;">Jelajahi Kategori</h4>
                    <div class="sidebar-cat-tags">
                        <% if (categories && categories.length> 0) { %>
                            <% categories.forEach(cat=> { %>
                                <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>" class="cat-badge" style="background-color: <%= catColor(cat.name) %>; color: #fff !important;"><%= cat.name %></a>
                            <% }) %>
                        <% } else { %>
                            <p style="color: var(--text-muted); font-size: 0.95rem;">Belum ada kategori.</p>
                        <% } %>
                    </div>
                </div>
            </aside>
        </div>
    </div>
</section>

    <%- include('../../partials/footer') %>