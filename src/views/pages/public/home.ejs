<%- include('../../partials/header', { title: 'eBlog-RPL - Insight Pengembang Perangkat Lunak' }) %>


    <section class="hero-slice<%= isLandingPage ? '' : ' hero-slice--compact' %>">
        <% if (isLandingPage) { %>
            <div class="hero-split-container">
                <div class="container hero-split-inner">
                    <div class="hero-left-content">
                        <span class="hero-badge">Divisi RPL SMK Pelita Nusantara</span>
                        <h1 class="hero-split-title">Insight & Update Rekayasa Perangkat Lunak</h1>
                        <p class="hero-split-sub">Temukan artikel berkualitas tinggi, tutorial coding, sains, dan
                            perkembangan teknologi terbaru langsung dari pengembang.</p>
                        <form class="hero-search-form" action="<%= BASE_PATH %>/search" method="GET">
                            <svg class="hero-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" aria-hidden="true">
                                <circle cx="11" cy="11" r="8" />
                                <path d="m21 21-4.35-4.35" />
                            </svg>
                            <input type="search" name="query"
                                placeholder="Cari topik, tutorial, atau bahasa pemrograman..." autocomplete="off">
                            <button type="submit">Cari</button>
                        </form>
                    </div>
                    <div class="hero-right-visual">
                        <div class="tech-card-glow"></div>
                        <div class="tech-canvas">
                            <div class="floating-code-line">const rpl = new SoftwareEngineer();</div>
                            <div class="tech-circle tech-circle-large"></div>
                            <div class="tech-circle tech-circle-mid"></div>
                            <div class="tech-circle tech-circle-small"></div>
                            <div class="tech-dots"></div>
                            <div class="tech-terminal">
                                <div class="terminal-header">
                                    <span class="dot red"></span>
                                    <span class="dot yellow"></span>
                                    <span class="dot green"></span>
                                    <span class="terminal-title">bash - rpl@devtrine</span>
                                </div>
                                <div class="terminal-body">
                                    <p class="cmd"><span class="prompt">$</span> npm run dev</p>
                                    <p class="out">Server running on port 5000</p>
                                    <p class="out success">✓ Build completed successfully!</p>
                                    <p class="cmd"><span class="prompt">$</span> <span class="cursor">_</span></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% } else { %>
                <div class="compact-header">
                    <div class="container">
                        <h1 class="compact-header-title">
                            <%= typeof title !=='undefined' ? title : 'Semua Artikel' %>
                        </h1>
                        <% if (typeof q !=='undefined' && q) { %>
                            <p class="compact-header-sub">Hasil pencarian untuk kata kunci "<strong>
                                    <%= q %>
                                </strong>"</p>
                            <% } else { %>
                                <p class="compact-header-sub">Jelajahi berbagai artikel dan tutorial seputar rekayasa
                                    perangkat lunak.</p>
                                <% } %>
                                    <form class="hero-search-form compact-search-form" action="<%= BASE_PATH %>/search"
                                        method="GET">
                                        <svg class="hero-search-icon" width="18" height="18" viewBox="0 0 24 24"
                                            fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                            <circle cx="11" cy="11" r="8" />
                                            <path d="m21 21-4.35-4.35" />
                                        </svg>
                                        <input type="search" name="query"
                                            value="<%= typeof q !== 'undefined' ? q : '' %>"
                                            placeholder="Cari topik atau kata kunci lain..." autocomplete="off">
                                        <button type="submit">Cari</button>
                                    </form>
                    </div>
                </div>
                <% } %>

                    <% if (isLandingPage) { %>
                        <div class="container landing-divider">
                            <hr class="dashed-rule">
                        </div>

                        <div class="container landing-hero-grid-wrap">
                            <div class="hero-grid-layout">

                                <% if (posts && posts.length> 0) { %>
                                    <% var featuredPost=posts[0]; %>
                                        <article class="featured-post-card hero-item-featured">
                                            <div class="featured-post-thumb">
                                                <% if (featuredPost.thumbnail) { %>
                                                    <img src="<%= featuredPost.thumbnail %>"
                                                        alt="<%= featuredPost.title %>">
                                                    <% } else { %>
                                                        <div class="featured-post-thumb-placeholder"></div>
                                                        <% } %>
                                                            <% if (featuredPost.Category) { %>
                                                                <span class="featured-post-cat"
                                                                    style="--cat-color: <%= catColor(featuredPost.Category.name) %>;">
                                                                    <%= featuredPost.Category.name %>
                                                                </span>
                                                                <% } %>
                                            </div>
                                            <div class="featured-post-body">
                                                <h2 class="featured-post-title">
                                                    <a href="<%= BASE_PATH %>/posts/<%= featuredPost.slug %>">
                                                        <%= featuredPost.title %>
                                                    </a>
                                                </h2>
                                                <div class="featured-post-meta">
                                                    <span>Oleh <%= featuredPost.User ? featuredPost.User.username
                                                            : 'Admin' %></span>
                                                    <span>
                                                        <%= new Date(featuredPost.createdAt).toLocaleDateString('id-ID',
                                                            { month: 'long' , day: 'numeric' , year: 'numeric' }) %>
                                                    </span>
                                                </div>
                                                <p class="featured-post-excerpt">
                                                    <%= featuredPost.content.replace(/[#*`]/g, '' ).substring(0, 180) %>
                                                        …
                                                </p>
                                                <a href="<%= BASE_PATH %>/posts/<%= featuredPost.slug %>"
                                                    class="featured-post-link">
                                                    Baca selengkapnya
                                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                        <path d="M5 12h14M12 5l7 7-7 7" />
                                                    </svg>
                                                </a>
                                            </div>
                                        </article>
                                        <% } %>

                                            <div class="hero-item-categories category-topics-widget">
                                                <div class="widget-header">
                                                    <h3 class="widget-title">Topik Kategori</h3>
                                                    <a href="<%= BASE_PATH %>/categories" class="widget-more-link">
                                                        Selengkapnya
                                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                                            stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                            <path d="M5 12h14M12 5l7 7-7 7" />
                                                        </svg>
                                                    </a>
                                                </div>
                                                <div class="cat-badge-list">
                                                    <% if (categories && categories.length> 0) { %>
                                                        <% categories.slice(0, 12).forEach(cat=> { %>
                                                            <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"
                                                                class="cat-badge"
                                                                style="--cat-color: <%= catColor(cat.name) %>;">
                                                                <%= cat.name %>
                                                            </a>
                                                            <% }) %>
                                                                <% } %>
                                                </div>
                                            </div>

                                            <% if (posts && posts.length> 1) { %>
                                                <div class="hero-item-trending trending-posts-widget">
                                                    <h3 class="widget-title">Postingan Trending</h3>
                                                    <div class="trending-list">
                                                        <% posts.slice(1, 5).forEach((post, idx)=> { %>
                                                            <a href="<%= BASE_PATH %>/posts/<%= post.slug %>"
                                                                class="trending-item<%= idx > 0 ? ' trending-item--bordered' : '' %>">
                                                                <span class="trending-rank">0<%= idx + 1 %></span>
                                                                <div class="trending-info">
                                                                    <h4 class="trending-title">
                                                                        <%= post.title %>
                                                                    </h4>
                                                                    <div class="trending-meta">
                                                                        <% if (post.Category) { %>
                                                                            <span class="trending-cat"
                                                                                style="--cat-color: <%= catColor(post.Category.name) %>;">
                                                                                <%= post.Category.name %>
                                                                            </span>
                                                                            <% } %>
                                                                                <span>
                                                                                    <%= new
                                                                                        Date(post.createdAt).toLocaleDateString('id-ID',
                                                                                        { month: 'short' ,
                                                                                        day: 'numeric' }) %>
                                                                                </span>
                                                                    </div>
                                                                </div>
                                                            </a>
                                                            <% }) %>
                                                    </div>
                                                </div>
                                                <% } %>

                            </div>
                        </div>
                        <% } %>
    </section>

    <section class="latest-posts-slice<%= isLandingPage ? '' : ' latest-posts-slice--light' %>">
        <div class="container">
            <% if (!isLandingPage) { %>
                <hr class="dashed-rule">
                <% } %>
                    <h2 class="section-title">
                        <%= isLandingPage ? 'Postingan Terbaru' : (typeof title !=='undefined' ? title
                            : 'Daftar Artikel' ) %>
                    </h2>

                    <div class="posts-grid">
                        <% var displayPosts=isLandingPage ? posts.slice(1, 4) : posts; if (displayPosts &&
                            displayPosts.length> 0) {
                            %>
                            <% displayPosts.forEach(post=> { %>
                                <%- include('../../partials/post-card', { post, BASE_PATH, catColor }) %>
                                    <% }) %>
                                        <% } else { %>
                                            <p class="posts-empty">Belum ada artikel. Cek lagi nanti!</p>
                                            <% } %>
                    </div>
        </div>
    </section>

    <% if (isLandingPage) { var categoriesWithPosts=[]; if (categories && categories.length> 0) {
        categories.forEach(cat => {
        var catPosts = posts.filter(p => p.Category && p.Category.id === cat.id);
        if (catPosts.length > 0) {
        categoriesWithPosts.push({ category: cat, posts: catPosts });
        }
        });
        }
        %>
        <% categoriesWithPosts.slice(0, 2).forEach(group=> { %>
            <section class="category-highlight-slice">
                <div class="container">
                    <hr class="dashed-rule">
                    <div class="section-header">
                        <h2 class="section-title">
                            <%= group.category.name %>
                        </h2>
                        <a href="<%= BASE_PATH %>/posts/category/<%= group.category.slug %>" class="section-more-link">
                            Lihat Semua
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2" aria-hidden="true">
                                <path d="M5 12h14M12 5l7 7-7 7" />
                            </svg>
                        </a>
                    </div>
                    <div class="posts-grid">
                        <% group.posts.slice(0, 3).forEach(post=> { %>
                            <%- include('../../partials/post-card', { post, BASE_PATH, catColor }) %>
                                <% }) %>
                    </div>
                </div>
            </section>
            <% }) %>
                <% } %>

                    <%- include('../../partials/footer') %>