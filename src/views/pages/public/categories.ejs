<%- include('../../partials/header', { title: 'Kategori - eBlog-RPL' }) %>

<section class="hero-post" style="padding: 4rem 0 3rem; text-align: left; background: linear-gradient(180deg, #f8f9ff 0%, #fff 100%);">
    <div class="container">
        <h1 style="font-size: 3.5rem; margin-bottom: 1.5rem; margin-left: 0; font-weight: 900; letter-spacing: -0.02em;">Kategori</h1>
        <p style="color: var(--text-muted); font-size: 1.3rem; max-width: 700px; line-height: 1.6;">
            Telusuri artikel kami berdasarkan topik untuk menemukan insight yang paling relevan bagi Anda.
        </p>
    </div>
</section>

<style>
    .bento-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: 75px;
        grid-auto-flow: dense;
        gap: 8px;
        width: 100%;
    }

    .bento-item {
        color: #ffffff !important;
        border-radius: 12px;
        text-decoration: none;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 12px 16px;
        position: relative;
        overflow: hidden;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .bento-item:hover, .bento-item:focus {
        color: #ffffff !important;
        transform: translateY(-2px) scale(1.015);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
    }

    .bento-item .bento-content {
        z-index: 2;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
    }

    .bento-title {
        font-family: var(--font-heading, inherit);
        font-size: 1.15rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.01em;
        line-height: 1.2;
    }

    .bento-item::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, rgba(0,0,0,0.15) 100%);
        z-index: 1;
        pointer-events: none;
    }

    .span-w2-h2 { grid-column: span 2; grid-row: span 2; }
    .span-w1-h3 { grid-column: span 1; grid-row: span 3; }
    .span-w1-h2 { grid-column: span 1; grid-row: span 2; }
    .span-w2-h1 { grid-column: span 2; grid-row: span 1; }
    .span-w1-h1 { grid-column: span 1; grid-row: span 1; }

    .span-w2-h2 .bento-title { font-size: 1.5rem; }
    .span-w1-h3 .bento-title { font-size: 1.35rem; }
    .span-w1-h1 .bento-title { font-size: 0.95rem; }

    @media (max-width: 1024px) {
        .bento-grid {
            grid-template-columns: repeat(3, 1fr);
            grid-auto-rows: 70px;
            gap: 8px;
        }
        .span-w1-h3 { grid-row: span 2; }
    }

    @media (max-width: 768px) {
        .bento-grid {
            grid-template-columns: repeat(2, 1fr);
            grid-auto-rows: 65px;
            gap: 8px;
        }
        .span-w2-h2 { grid-column: span 2; grid-row: span 2; }
        .span-w1-h3 { grid-column: span 1; grid-row: span 2; }
        .span-w2-h1 { grid-column: span 2; grid-row: span 1; }
        .span-w1-h2 { grid-column: span 1; grid-row: span 2; }
        
        .bento-title { font-size: 1rem; }
        .span-w2-h2 .bento-title { font-size: 1.25rem; }
        .span-w1-h3 .bento-title { font-size: 1.15rem; }
        .span-w1-h1 .bento-title { font-size: 0.85rem; }
    }

    @media (max-width: 480px) {
        .bento-grid {
            grid-template-columns: repeat(2, 1fr);
            grid-auto-rows: 55px;
            gap: 6px;
        }
        .bento-item {
            padding: 8px 12px;
            border-radius: 8px;
        }
        .span-w2-h2 { grid-column: span 2; grid-row: span 2; }
        .span-w1-h3 { grid-column: span 1; grid-row: span 2; }
        .span-w2-h1 { grid-column: span 2; grid-row: span 1; }
        .span-w1-h2 { grid-column: span 1; grid-row: span 2; }

        .bento-title { font-size: 0.9rem; }
        .span-w2-h2 .bento-title { font-size: 1.15rem; }
        .span-w1-h3 .bento-title { font-size: 1.05rem; }
        .span-w1-h1 .bento-title { font-size: 0.8rem; }
    }
</style>

<div class="container" style="padding: 2rem 3rem 4rem; max-width: 1400px;">
    <div class="bento-grid">
        <% if (typeof categories !== 'undefined' && categories.length > 0) { 
            const gridPatterns = [
                'span-w2-h2',
                'span-w1-h3',
                'span-w1-h1',
                'span-w2-h1',
                'span-w1-h2',
                'span-w1-h1',
                'span-w2-h1',
                'span-w1-h2',
                'span-w1-h1',
                'span-w2-h2',
                'span-w2-h1',
                'span-w2-h2',
                'span-w2-h1'
            ];
        %>
            <% categories.forEach((cat, idx) => { 
                var pattern = gridPatterns[idx % gridPatterns.length];
            %>
                <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>" class="bento-item <%= pattern %>" style="background-color: <%= catColor(cat.name) %>;">
                    <div class="bento-content">
                        <h3 class="bento-title"><%= cat.name %></h3>
                    </div>
                </a>
            <% }) %>
        <% } else { %>
            <p style="color: var(--text-muted); font-size: 1.1rem; grid-column: 1 / -1; text-align: center; padding: 4rem 0;">Belum ada kategori.</p>
        <% } %>
    </div>
</div>

<%- include('../../partials/footer') %>
