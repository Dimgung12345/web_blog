<%- include('../../partials/header', { title: 'Kategori - eBlog-RPL' }) %>

<%
var catColors = ['#0069ff','#8b5cf6','#10b981','#f59e0b','#ef4444','#ec4899','#06b6d4','#f97316'];
function catColor(name) {
    var h = 0;
    for (var i = 0; i < name.length; i++) { h = ((h << 5) - h) + name.charCodeAt(i); h |= 0; }
    return catColors[Math.abs(h) % catColors.length];
}
%>

<section class="hero-post" style="padding: 4rem 0; text-align: left;">
    <div class="container">
        <h1 style="font-size: 3rem; margin-bottom: 1rem; margin-left: 0;">Kategori</h1>
        <p style="color: var(--text-muted); font-size: 1.2rem; max-width: 600px;">
            Telusuri artikel kami berdasarkan topik untuk menemukan insight yang paling relevan bagi Anda.
        </p>
    </div>
</section>

<div class="container" style="padding: 2rem 0 5rem;">
    <div class="category-tags">
        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
            <% categories.forEach(cat => { %>
                <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>" class="category-tag-pill" style="background-color: <%= catColor(cat.name) %>;"><%= cat.name %></a>
            <% }) %>
        <% } else { %>
            <p style="color: var(--text-muted); font-size: 1.1rem;">Belum ada kategori.</p>
        <% } %>
    </div>
</div>

<%- include('../../partials/footer') %>
