<%- include('../../partials/header', { title: 'Kategori - eBlog-RPL' }) %>

<section class="hero-post categories-hero">
    <div class="container">
        <h1 class="categories-hero-title">Kategori</h1>
        <p class="categories-hero-sub">Telusuri artikel kami berdasarkan topik untuk menemukan insight yang paling relevan bagi Anda.</p>
    </div>
</section>

<div class="container categories-bento-wrap">
    <div class="bento-grid">
        <% if (typeof categories !== 'undefined' && categories.length > 0) {
            const gridPatterns = [
                'span-w2-h2',
                'span-w1-h3',
                'span-w1-h1',
                'span-w2-h1',
                'span-w1-h2',
                'span-w1-h1',
                'span-w2-h1',
                'span-w1-h2',
                'span-w1-h1',
                'span-w2-h2',
                'span-w2-h1',
                'span-w2-h2',
                'span-w2-h1'
            ];
        %>
            <% categories.forEach((cat, idx) => {
                var pattern = gridPatterns[idx % gridPatterns.length];
            %>
                <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"
                   class="bento-item <%= pattern %>"
                   style="--cat-color: <%= catColor(cat.name) %>;">
                    <div class="bento-content">
                        <h3 class="bento-title"><%= cat.name %></h3>
                    </div>
                </a>
            <% }) %>
        <% } else { %>
            <p class="posts-empty">Belum ada kategori.</p>
        <% } %>
    </div>
</div>

<%- include('../../partials/footer') %>
