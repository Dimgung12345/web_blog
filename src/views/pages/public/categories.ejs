<%- include('../../partials/header', { title: 'Kategori - Blog', activeNav: 'categories' }) %>

    <section class="hero">
        <div class="container">
            <h1>Kategori</h1>
            <p class="hero-sub">Telusuri artikel kami berdasarkan topik untuk menemukan insight yang paling relevan bagi Anda.</p>
        </div>
    </section>

    <div class="container">
        <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
            <div class="cat-grid">
                <% categories.forEach(function (cat) { %>
                    <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"
                       class="cat-box" style="--cat-color: <%= catColor(cat.name) %>;">
                        <span class="cat-box-name"><%= cat.name %></span>
                    </a>
                <% }); %>
            </div>
        <% } else { %>
            <div class="empty-note">Belum ada kategori.</div>
        <% } %>
    </div>

    <%- include('../../partials/footer') %>
