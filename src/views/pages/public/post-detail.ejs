<%- include('../../partials/header', { title: post.title + ' - Blog' }) %>

<div style="max-width: 800px; margin: 0 auto; background: white; padding: 20px; font-family: Arial, sans-serif;">
    <!-- Breadcrumb -->
    <div style="font-size: 13px; color: #e67e22; font-weight: bold; margin-bottom: 15px; text-transform: uppercase;">
        <a href="<%= BASE_PATH %>" style="color: #e67e22; text-decoration: none;">BLOG.COM</a> 
        <span style="color: #ccc;">></span> 
        <% if (post.Category) { %>
            <a href="<%= BASE_PATH %>/posts/category/<%= post.Category.slug %>" style="color: #e67e22; text-decoration: none;"><%= post.Category.name %></a>
        <% } else { %>
            NEWS
        <% } %>
    </div>

    <!-- Title -->
    <h1 style="color: #222; font-size: 32px; line-height: 1.3; margin: 0 0 15px 0;">
        <%= post.title %>
    </h1>

    <!-- Author & Date -->
    <div style="font-size: 14px; color: #777; border-bottom: 1px solid #eaeaea; padding-bottom: 15px; margin-bottom: 25px;">
        <div style="margin-bottom: 5px;">
            <strong>Blog.com,</strong> 
            <%= new Date(post.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %>, 
            <%= new Date(post.createdAt).toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' }) %> WIB
        </div>
        <div>
            Penulis: <strong><%= post.User ? post.User.username : 'Tim Redaksi' %></strong>
        </div>
    </div>

    <!-- Placeholder Image -->
    <div style="width: 100%; height: 400px; background-color: #f1f1f1; display: flex; align-items: center; justify-content: center; color: #aaa; margin-bottom: 10px;">
        [ Hero Image Placeholder ]
    </div>
    <div style="font-size: 12px; color: #999; margin-bottom: 30px;">
        Ilustrasi gambar artikel (Dok. Blog)
    </div>

    <!-- Content -->
    <article style="line-height: 1.8; color: #333; font-size: 17px; white-space: pre-wrap;">
        <span style="font-weight: bold;">JAKARTA, BLOG.COM - </span><%= post.content %>
    </article>
</div>

<%- include('../../partials/footer') %>
