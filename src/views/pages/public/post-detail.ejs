<%- include('../../partials/header') %>

<%
var catColors = ['#0069ff','#8b5cf6','#10b981','#f59e0b','#ef4444','#ec4899','#06b6d4','#f97316'];
function catColor(name) {
    var h = 0;
    for (var i = 0; i < name.length; i++) { h = ((h << 5) - h) + name.charCodeAt(i); h |= 0; }
    return catColors[Math.abs(h) % catColors.length];
}
var catName = post.Category ? post.Category.name : 'General';
var color = catColor(catName);
function hexToRgb(hex) {
    var r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
    return r+','+g+','+b;
}
var rgb = hexToRgb(color);
var sliceBg = 'linear-gradient(180deg, rgba('+rgb+',0.08) 0%, rgba('+rgb+',0.03) 50%, #fff 100%)';
%>

<section class="hero-slice" style="background: <%= sliceBg %>;">
    <section class="hero-post">
        <div class="container">
        <% if (post.Category) { %>
            <div class="category-tag" style="background-color: <%= color %>;">
                <a href="<%= BASE_PATH %>/posts/category/<%= post.Category.slug %>" style="color: white;"><%= post.Category.name %></a>
            </div>
        <% } %>
        <h1><%= post.title %></h1>
        <div class="post-meta-details">
            <div class="author-info">
                <div class="author-avatar"></div>
                <span style="font-weight: 600; color: var(--text-main);">Oleh <%= post.User ? post.User.username : 'Admin' %></span>
            </div>
            <ul class="post-stats">
                <li>Terbit: <%= new Date(post.createdAt).toLocaleDateString('id-ID', { month: 'long', day: 'numeric', year: 'numeric' }) %></li>
                <li><%= readingTime %> menit baca</li>
            </ul>
        </div>
        </div>
    </section>
</section>

        <div class="container" style="max-width: 1400px;">
    <div class="post-layout" id="post-layout">
        <button class="mobile-toc-edge" id="mobile-toc-edge" aria-label="Daftar Isi">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
        <div class="mobile-toc-panel" id="mobile-toc-panel">
            <div class="mobile-toc-panel-header">
                <span>Daftar Isi</span>
                <button class="mobile-toc-close" id="mobile-toc-close" aria-label="Close">&times;</button>
            </div>
            <ul class="toc-list" id="toc-mobile">
                <% toc.forEach((item, index) => { %>
                    <li class="toc-item <%= index === 0 ? 'active' : '' %>">
                        <a href="#<%= item.id %>" style="padding-left: <%= 16 + (item.level - 1) * 16 %>px;">
                            <%= item.text %>
                        </a>
                    </li>
                <% }) %>
            </ul>
        </div>

        <aside class="toc-sidebar" id="toc-sidebar">
            <h3>Daftar Isi</h3>
            <ul class="toc-list" id="toc">
                <% toc.forEach((item, index) => { %>
                    <li class="toc-item <%= index === 0 ? 'active' : '' %>">
                        <a href="#<%= item.id %>" style="padding-left: <%= 24 + (item.level - 1) * 20 %>px;">
                            <%= item.text %>
                        </a>
                    </li>
                <% }) %>
            </ul>
        </aside>

        <article class="markdown-content">
            <%- contentHtml %>
        </article>

        <aside class="right-sidebar">
            <div class="sidebar-widget">
                <h4>Bagikan</h4>
                <div class="social-share-buttons">
                    <a href="#" class="share-btn" title="Share on Twitter">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
                    </a>
                    <a href="#" class="share-btn" title="Share on Facebook">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                    </a>
                    <a href="#" class="share-btn" title="Share on LinkedIn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"></path></svg>
                    </a>
                </div>
            </div>

            <div class="sidebar-widget">
                <h4>Kategori</h4>
                <div class="sidebar-cat-tags">
                    <% categories.forEach(cat => { %>
                        <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>" class="cat-badge" style="background-color: <%= catColor(cat.name) %>; color: #fff !important;"><%= cat.name %></a>
                    <% }) %>
                </div>
            </div>

            <% if (relatedPosts && relatedPosts.length > 0) { %>
            <div class="sidebar-widget">
                <h4>Artikel Terkait</h4>
                <ul class="related-articles">
                    <% relatedPosts.forEach(rel => { %>
                        <li class="related-item">
                            <a href="<%= BASE_PATH %>/posts/<%= rel.slug %>"><%= rel.title %></a>
                            <span><%= new Date(rel.createdAt).toLocaleDateString() %></span>
                        </li>
                    <% }) %>
                </ul>
            </div>
            <% } %>
        </aside>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        hljs.highlightAll();

        var tocItems = document.querySelectorAll('#toc .toc-item, #toc-mobile .toc-item');
        var headers = Array.from(document.querySelectorAll('.markdown-content h1, .markdown-content h2, .markdown-content h3'));

        document.querySelectorAll('.toc-item a').forEach(anchor => {
            anchor.addEventListener('click', function(e) {
                e.preventDefault();
                var targetId = this.getAttribute('href').substring(1);
                var targetElement = document.getElementById(targetId);
                if (targetElement) {
                    tocItems.forEach(item => item.classList.remove('active'));
                    document.querySelectorAll('.toc-item a[href="#' + targetId + '"]').forEach(a => a.parentElement.classList.add('active'));
                    window.scrollTo({ top: targetElement.offsetTop - 100, behavior: 'smooth' });
                    history.pushState(null, null, '#' + targetId);
                    var mp = document.getElementById('mobile-toc-panel');
                    var eb = document.getElementById('mobile-toc-edge');
                    if (mp && mp.classList.contains('open')) {
                        mp.classList.remove('open');
                        if (eb) eb.classList.remove('open');
                    }
                }
            });
        });

        var observerOptions = { root: null, rootMargin: '-10% 0px -70% 0px', threshold: 0 };
        var observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    var id = entry.target.getAttribute('id');
                    tocItems.forEach(item => item.classList.remove('active'));
                    document.querySelectorAll('.toc-item a[href="#' + id + '"]').forEach(a => a.parentElement.classList.add('active'));
                }
            });
        }, observerOptions);
        headers.forEach(header => {
            if (!header.id) header.id = header.innerText.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
            observer.observe(header);
        });

        var edgeBtn = document.getElementById('mobile-toc-edge');
        var panel = document.getElementById('mobile-toc-panel');
        var closeBtn = document.getElementById('mobile-toc-close');

        if (edgeBtn && panel) {
            edgeBtn.addEventListener('click', function() {
                panel.classList.toggle('open');
                edgeBtn.classList.toggle('open');
            });
        }
        if (closeBtn && panel) {
            closeBtn.addEventListener('click', function() {
                panel.classList.remove('open');
                edgeBtn.classList.remove('open');
            });
        }
    });
</script>

<%- include('../../partials/footer') %>
