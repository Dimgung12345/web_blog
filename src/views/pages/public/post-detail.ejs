<%- include('../../partials/header') %>

<%
var catName = post.Category ? post.Category.name : 'General';
var color   = catColor(catName);
var sliceBg = 'linear-gradient(180deg, color-mix(in srgb, ' + color + ' 8%, transparent) 0%, color-mix(in srgb, ' + color + ' 3%, transparent) 50%, #fff 100%)';
%>

<section class="hero-slice hero-slice--compact" style="background: <%= sliceBg %>;">
    <section class="hero-post">
        <div class="container">
            <% if (post.Category) { %>
                <div class="category-tag" style="background-color: <%= color %>;">
                    <a href="<%= BASE_PATH %>/posts/category/<%= post.Category.slug %>"><%= post.Category.name %></a>
                </div>
            <% } %>
            <h1><%= post.title %></h1>
            <div class="post-meta-details">
                <div class="author-info">
                    <div class="author-avatar"></div>
                    <span class="author-name">Oleh <%= post.User ? post.User.username : 'Admin' %></span>
                </div>
                <ul class="post-stats">
                    <li>Terbit: <%= new Date(post.createdAt).toLocaleDateString('id-ID', { month: 'long', day: 'numeric', year: 'numeric' }) %></li>
                    <li><%= readingTime %> menit baca</li>
                </ul>
            </div>
        </div>
    </section>
</section>

<div class="container post-detail-wrap">
    <div class="post-layout" id="post-layout">

        <button class="mobile-toc-edge" id="mobile-toc-edge" aria-label="Daftar Isi">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"/>
            </svg>
        </button>

        <div class="mobile-toc-panel" id="mobile-toc-panel">
            <div class="mobile-toc-panel-header">
                <button class="mobile-toc-close" id="mobile-toc-close" aria-label="Tutup daftar isi">&times;</button>
            </div>
            <ul class="toc-list" id="toc-mobile">
                <li class="toc-item toc-header-item">
                    <span class="toc-label">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
                            <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
                            <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                        </svg>
                        Daftar Isi
                    </span>
                </li>
                <% toc.forEach((item, index) => { %>
                    <li class="toc-item <%= index === 0 ? 'active' : '' %>">
                        <a href="#<%= item.id %>" style="padding-left: <%= 16 + (item.level - 1) * 16 %>px;">
                            <%= item.text %>
                        </a>
                    </li>
                <% }) %>
            </ul>
        </div>

        <aside class="toc-sidebar" id="toc-sidebar">
            <h3>Daftar Isi</h3>
            <ul class="toc-list" id="toc">
                <% toc.forEach((item, index) => { %>
                    <li class="toc-item <%= index === 0 ? 'active' : '' %>">
                        <a href="#<%= item.id %>" style="padding-left: <%= 24 + (item.level - 1) * 20 %>px;">
                            <%= item.text %>
                        </a>
                    </li>
                <% }) %>
            </ul>
        </aside>

        <article class="markdown-content">
            <%- contentHtml %>
        </article>

        <aside class="right-sidebar">
            <div class="sidebar-widget" x-data="{
                liked: false,
                count: 0,
                loading: false,
                init() {
                    fetch('<%= BASE_PATH %>/api/likes/<%= post.id %>/count').then(r=>r.json()).then(d=>{ this.count = d.count }).catch(()=>{});
                    fetch('<%= BASE_PATH %>/api/likes/<%= post.id %>/check').then(r=>r.ok?r.json():{liked:false}).then(d=>{ this.liked = d.liked }).catch(()=>{});
                },
                toggle() {
                    if (this.loading) return;
                    this.loading = true;
                    fetch('<%= BASE_PATH %>/api/likes/<%= post.id %>/toggle', { method:'POST' })
                        .then(r=>r.ok?r.json():Promise.reject())
                        .then(d=>{ this.liked = d.liked; this.count = d.count })
                        .catch(()=>{ alert('Silakan login untuk memberi like'); })
                        .finally(()=>{ this.loading = false });
                }
            }">
                <h4>Suka</h4>
                <div class="like-row">
                    <button class="like-btn" @click="toggle()" :disabled="loading"
                            :class="{ 'like-btn--active': liked }">
                        <svg x-show="!liked" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                        <svg x-show="liked" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                        <span x-text="count" class="like-count"></span>
                    </button>
                    <span x-show="loading" class="like-loading">...</span>
                </div>
            </div>

            <div class="sidebar-widget">
                <h4>Bagikan</h4>
                <div class="social-share-buttons">
                    <a href="#" class="share-btn" title="Bagikan ke X (Twitter)">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href="#" class="share-btn" title="Bagikan ke Facebook">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                    <a href="#" class="share-btn" title="Bagikan ke LinkedIn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
                    </a>
                </div>
            </div>

            <div class="sidebar-widget">
                <h4>Jelajahi Kategori</h4>
                <div class="cat-badge-list">
                    <%
                        var currentCatId = post.Category ? post.Category.id : null;
                        var displayCats  = [];
                        if (post.Category) displayCats.push(post.Category);
                        if (categories && categories.length > 0) {
                            categories.forEach(cat => {
                                if (!currentCatId || cat.id !== currentCatId) displayCats.push(cat);
                            });
                        }
                        displayCats = displayCats.slice(0, 4);
                    %>
                    <% if (displayCats.length > 0) { %>
                        <% displayCats.forEach(cat => { %>
                            <% var isCurrent = (currentCatId && cat.id === currentCatId); %>
                            <a href="<%= BASE_PATH %>/posts/category/<%= cat.slug %>"
                               class="cat-badge<%= isCurrent ? ' cat-badge--current' : '' %>"
                               style="--cat-color: <%= isCurrent ? '#94a3b8' : catColor(cat.name) %>;">
                                <%= cat.name %>
                            </a>
                        <% }) %>
                    <% } else { %>
                        <p class="posts-empty">Belum ada kategori.</p>
                    <% } %>
                </div>
            </div>
        </aside>
    </div>

    <% if (relatedPosts && relatedPosts.length > 0) { %>
        <section class="related-posts-section">
            <h3 class="related-posts-title">Postingan Relevan</h3>
            <div class="posts-grid">
                <% relatedPosts.slice(0, 3).forEach(post => { %>
                    <%- include('../../partials/post-card', { post, BASE_PATH, catColor }) %>
                <% }) %>
            </div>
        </section>
    <% } %>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    hljs.highlightAll();

    const tocItems = document.querySelectorAll('#toc .toc-item, #toc-mobile .toc-item');
    const headers  = Array.from(document.querySelectorAll('.markdown-content h1, .markdown-content h2, .markdown-content h3'));

    document.querySelectorAll('.toc-item a').forEach(anchor => {
        anchor.addEventListener('click', e => {
            e.preventDefault();
            const id  = anchor.getAttribute('href').slice(1);
            const el  = document.getElementById(id);
            if (!el) return;
            tocItems.forEach(i => i.classList.remove('active'));
            document.querySelectorAll(`.toc-item a[href="#${id}"]`).forEach(a => a.parentElement.classList.add('active'));
            window.scrollTo({ top: el.offsetTop - 100, behavior: 'smooth' });
            history.pushState(null, null, '#' + id);
            closePanel();
        });
    });

    const observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
            if (!entry.isIntersecting) return;
            const id = entry.target.id;
            tocItems.forEach(i => i.classList.remove('active'));
            document.querySelectorAll(`.toc-item a[href="#${id}"]`).forEach(a => a.parentElement.classList.add('active'));
        });
    }, { rootMargin: '-10% 0px -70% 0px', threshold: 0 });

    headers.forEach(h => {
        if (!h.id) h.id = h.innerText.toLowerCase().replace(/[^\w\s-]/g, '').replace(/\s+/g, '-');
        observer.observe(h);
    });

    const edgeBtn  = document.getElementById('mobile-toc-edge');
    const panel    = document.getElementById('mobile-toc-panel');
    const closeBtn = document.getElementById('mobile-toc-close');

    function closePanel() {
        if (!panel) return;
        panel.classList.remove('open');
        if (edgeBtn) edgeBtn.classList.remove('open');
    }

    edgeBtn?.addEventListener('click', () => {
        panel.classList.toggle('open');
        edgeBtn.classList.toggle('open');
    });

    fetch('<%= BASE_PATH %>/api/popularity/<%= post.id %>/view', { method: 'PATCH' })
        .catch(err => console.error("Error logging view:", err));
});
</script>

<%- include('../../partials/footer') %>
