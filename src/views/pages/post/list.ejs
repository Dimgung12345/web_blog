<%- include('../../partials/header', { title: 'Daftar Post - Blog', activeNav: 'posts' }) %>

    <section class="hero">
        <div class="container">
            <h1>Daftar Post</h1>
            <p class="hero-sub">Seluruh artikel yang telah dipublikasikan.</p>
        </div>
    </section>

    <div class="container">
        <div class="panel">
            <div class="panel-title">Semua Postingan</div>
            <div class="panel-body" style="padding:0;">
                <ul class="cat-list" style="padding:8px 0;">
                    <% posts.forEach(function (post) { %>
                        <li>
                            <a href="<%= BASE_PATH %>/posts/<%= post.slug %>">
                                <%= post.title %> <span class="text-secondary">— oleh <%= post.User.username %></span>
                            </a>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>

    <%- include('../../partials/footer') %>
