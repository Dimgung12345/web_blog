<%- include('../../partials/header', { title: 'Admin Dashboard - Blog' }) %>
    <div
        style="max-width: 900px; margin: 30px auto; background: white; padding: 30px; border-radius: 8px; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
        <div
            style="display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #ecf0f1; padding-bottom: 10px; margin-bottom: 20px;">
            <h1 style="color: #2c3e50; margin: 0;">Dashboard Admin</h1>
            <button onclick="logout()"
                style="padding: 8px 12px; background: #e74c3c; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">Logout</button>
        </div>

        <div style="margin-bottom: 20px;">
            <button onclick="resetForm(); document.getElementById('post-form').style.display='block'"
                style="padding: 10px 15px; background: #27ae60; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">+
                Tulis Post Baru</button>
        </div>

        <div id="post-form"
            style="display: none; background: #f9f9f9; padding: 20px; border-radius: 8px; margin-bottom: 30px; border: 1px solid #ddd;">
            <h3 id="form-title">Buat Postingan Baru</h3>
            <form onsubmit="submitPost(event)">
                <input type="text" id="post-title" placeholder="Judul" required
                    style="width: 100%; padding: 10px; margin-bottom: 15px; box-sizing: border-box;">
                <select id="post-category" required
                    style="width: 100%; padding: 10px; margin-bottom: 15px; box-sizing: border-box;">
                    <option value="">-- Pilih Kategori --</option>
                </select>
                <textarea id="post-content" placeholder="Isi postingan..." required rows="6"
                    style="width: 100%; padding: 10px; margin-bottom: 15px; box-sizing: border-box;"></textarea>
                <button type="submit"
                    style="padding: 10px 15px; background: #3498db; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">Simpan
                    Post</button>
                <button type="button" onclick="resetForm()"
                    style="padding: 10px 15px; background: #95a5a6; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; margin-left: 10px;">Batal</button>
            </form>
        </div>

        <h2>Daftar Postingan Anda</h2>
        <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
            <thead>
                <tr style="background: #34495e; color: white; text-align: left;">
                    <th style="padding: 12px; border: 1px solid #ddd;">Judul</th>
                    <th style="padding: 12px; border: 1px solid #ddd;">Kategori</th>
                    <th style="padding: 12px; border: 1px solid #ddd;">Aksi</th>
                </tr>
            </thead>
            <tbody id="admin-posts-list">
                <tr>
                    <td colspan="3" style="padding: 12px; text-align: center;">Loading...</td>
                </tr>
            </tbody>
        </table>
    </div>

    <script>
        const token = localStorage.getItem('token');
        if (!token) {
            window.location.href = '<%= BASE_PATH %>/login';
        }

        function logout() {
            localStorage.removeItem('token');
            window.location.href = '<%= BASE_PATH %>/login';
        }

        let editingPostId = null;

        async function loadData() {
            try {
                // Load Categories
                const catRes = await fetch('<%= BASE_PATH %>/categories', { headers: { 'Accept': 'application/json' } });
                const categories = await catRes.json();
                const catSelect = document.getElementById('post-category');
                
                if (Array.isArray(categories)) {
                    catSelect.innerHTML = '<option value="">-- Pilih Kategori --</option>';
                    categories.forEach(c => {
                        catSelect.innerHTML += `<option value="${c.id}">${c.name}</option>`;
                    });
                }

                // Load Posts
                const postRes = await fetch('<%= BASE_PATH %>/posts', { headers: { 'Accept': 'application/json' } });
                const posts = await postRes.json();
                const tbody = document.getElementById('admin-posts-list');

                if (!Array.isArray(posts) || posts.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="3" style="padding: 12px; text-align: center;">Belum ada postingan</td></tr>';
                    return;
                }

                tbody.innerHTML = '';
                posts.forEach(p => {
                    tbody.innerHTML += `
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 12px;">${p.title}</td>
                        <td style="padding: 12px;">${p.Category ? p.Category.name : '-'}</td>
                        <td style="padding: 12px;">
                            <button onclick='openEditForm(${JSON.stringify(p).replace(/'/g, "&apos;")})' style="padding: 5px 10px; background: #f39c12; color: white; border: none; border-radius: 3px; cursor: pointer; margin-right: 5px;">Edit</button>
                            <button onclick="deletePost(${p.id})" style="padding: 5px 10px; background: #e74c3c; color: white; border: none; border-radius: 3px; cursor: pointer;">Hapus</button>
                        </td>
                    </tr>
                `;
                });
            } catch (e) {
                console.error(e);
            }
        }

        function openEditForm(post) {
            editingPostId = post.id;
            document.getElementById('post-title').value = post.title;
            document.getElementById('post-category').value = post.CategoryId || "";
            document.getElementById('post-content').value = post.content;
            document.getElementById('form-title').textContent = "Edit Postingan";
            document.getElementById('post-form').style.display = 'block';
            document.getElementById('post-form').scrollIntoView({ behavior: 'smooth' });
        }

        function resetForm() {
            editingPostId = null;
            document.getElementById('post-title').value = '';
            document.getElementById('post-category').value = '';
            document.getElementById('post-content').value = '';
            document.getElementById('form-title').textContent = "Buat Postingan Baru";
            document.getElementById('post-form').style.display = 'none';
        }

        async function submitPost(e) {
            e.preventDefault();
            const title = document.getElementById('post-title').value;
            const categoryId = document.getElementById('post-category').value;
            const content = document.getElementById('post-content').value;

            const url = editingPostId ? `<%= BASE_PATH %>/posts/${editingPostId}` : '<%= BASE_PATH %>/posts';
            const method = editingPostId ? 'PUT' : 'POST';

            try {
                const res = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ title, CategoryId: categoryId, content })
                });

                if (res.ok) {
                    alert(editingPostId ? 'Berhasil memperbarui postingan!' : 'Berhasil membuat postingan!');
                    resetForm();
                    loadData();
                } else {
                    const data = await res.json();
                    alert('Gagal: ' + (data.error || data.message));
                }
            } catch (e) {
                alert('Error');
            }
        }

        async function deletePost(id) {
            if (!confirm('Yakin hapus?')) return;
            try {
                const res = await fetch(`<%= BASE_PATH %>/posts/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (res.ok) {
                    loadData();
                }
            } catch (e) {
                alert('Gagal hapus');
            }
        }

        loadData();
    </script>

    <%- include('../../partials/footer') %>
